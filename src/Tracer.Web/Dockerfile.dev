# Angular hot-reload image for docker-compose.dev.yml
FROM node:22-alpine

WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .

EXPOSE 4200

# proxy.docker.json routes /api → tracer-api on the Compose network
CMD ["npm", "run", "start", "--", "--host", "0.0.0.0", "--port", "4200", "--poll", "2000", "--proxy-config", "proxy.docker.json"]
